# Copy this file to `.env` and update values.

# Core
NODE_ENV=development
PORT=3001
API_BASE_URL=http://localhost:3001

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=your-redis-password

# Auth (only required for write operations in non-development)
# JWT_SECRET=your-jwt-secret-key-here

# PDF upload storage (required only if you use POST /api/queues/parsePdf/upload)
# S3_BUCKET=your-bucket-name
# Either set a stable base URL:
# S3_PUBLIC_BASE_URL=https://storage.googleapis.com/<bucket>
# Or derive it from a publicly routable endpoint:
# S3_ENDPOINT=https://storage.googleapis.com
#
# Optional S3 client settings (only needed for non-default auth/endpoints)
# S3_REGION=eu-north-1
# S3_ENDPOINT=https://your-s3-endpoint
# S3_ACCESS_KEY_ID=your-access-key
# S3_SECRET_ACCESS_KEY=your-secret-key
# S3_SESSION_TOKEN=your-session-token