# Environment Configuration
# Copy this file to .env and update with your values

# ============================================
# Required Environment Variables
# ============================================

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# API Configuration
NODE_ENV=development
PORT=3001

# ============================================
# Optional Environment Variables
# ============================================

# Redis Password (if your Redis instance requires authentication)
# REDIS_PASSWORD=your-redis-password

# API Base URL (default: http://localhost:3001)
API_BASE_URL=http://localhost:3001

# JWT Authentication
# JWT_SECRET: Secret key for JWT token validation. Must match the secret used by the main auth API (api.klimatkollen.se).
# Optional - only required for write operations (POST, PUT, PATCH, DELETE). GET requests work without it.
# JWT_SECRET=your-jwt-secret-key-here

# S3 (for POST /api/queues/parsePdf/upload - PDF file upload)
# Required only when using the parsePdf upload endpoint. Credentials: set below or use IAM role (e.g. in Kubernetes).
# S3_BUCKET=your-bucket-name
# AWS_REGION=eu-north-1
# S3_PRESIGNED_EXPIRY_SECONDS=86400
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
