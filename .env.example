# Environment Configuration
# Copy this file to .env and update with your values

# ============================================
# Required Environment Variables
# ============================================

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# API Configuration
NODE_ENV=development
PORT=3001

# ============================================
# Optional Environment Variables
# ============================================

# Redis Password (if your Redis instance requires authentication)
# REDIS_PASSWORD=your-redis-password

# API Base URL (default: http://localhost:3001)
API_BASE_URL=http://localhost:3001

# JWT Authentication
# JWT_SECRET: Secret key for JWT token validation. Must match the secret used by the main auth API (api.klimatkollen.se).
# Optional - only required for write operations (POST, PUT, PATCH, DELETE). GET requests work without it.
# JWT_SECRET=your-jwt-secret-key-here

# S3-compatible object storage (for POST /api/queues/parsePdf/upload - PDF file upload)
# Required only when using the parsePdf upload endpoint.
#
# Required:
# S3_BUCKET=your-bucket-name
#
# Optional:
# - **S3_ENDPOINT**: Set when using an S3-compatible provider (e.g. non-AWS) or a custom endpoint.
# - **S3_REGION**: Only used by the AWS SDK client; many S3-compatible providers ignore it. Defaults to eu-north-1.
# - **S3_PRESIGNED_EXPIRY_SECONDS**: Presigned GET URL expiry in seconds (default 86400; min 60; max 604800).
# - **Credentials**: Set these if not using workload identity / role-based auth.
# S3_ENDPOINT=https://your-s3-endpoint
# S3_REGION=eu-north-1
# S3_PRESIGNED_EXPIRY_SECONDS=86400
# S3_ACCESS_KEY_ID=your-access-key
# S3_SECRET_ACCESS_KEY=your-secret-key
# S3_SESSION_TOKEN=your-session-token
